<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8"/>
		<style>
			body {
				font-family: Arial, sans-serif;
				color: #111827;
				font-size: 12px;
			}
			.header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 16px;
				padding: 12px;
				background: #1f4ed8;
				color: #fff;
				border-radius: 8px;
			}
			.brand {
				display: flex;
				align-items: center;
				gap: 12px;
			}
			.brand img {
				height: 42px;
			}
			.title {
				font-size: 20px;
				font-weight: 700;
			}
			.meta {
				text-align: right;
				font-size: 11px;
				opacity: 0.9;
			}
			.card {
				border: 1px solid #e5e7eb;
				border-radius: 8px;
				padding: 12px;
				margin-bottom: 12px;
			}
			.card h3 {
				margin: 0 0 8px;
				font-size: 13px;
				text-transform: uppercase;
				color: #111827;
			}
			.table {
				width: 100%;
				border-collapse: collapse;
			}
			.table th,
			.table td {
				border: 1px solid #e5e7eb;
				padding: 6px 8px;
			}
			.table th {
				background: #f3f4f6;
				text-align: left;
				font-weight: 600;
			}
			.text-end {
				text-align: right;
			}
			.highlight {
				background: #eef2ff;
				font-weight: 700;
			}
			.grid {
				display: flex;
				gap: 12px;
			}
			.grid > div {
				flex: 1;
			}
		</style>
	</head>
	<body>
		<div class="header">
			<div class="brand">
				<img src="{{ logoDataUri }}" alt="logo"/>
				<div class="title">Payslip</div>
			</div>
			<div class="meta">
				<div>Period:
					{{ neooStart|date('Y-m-d') }}
					->
					{{ neooEnd|date('Y-m-d') }}</div>
				<div>Generated:
					{{ "now"|date('Y-m-d H:i') }}</div>
			</div>
		</div>

		<div class="card">
			<div class="grid">
				<div>
					<h3>Driver</h3>
					<div>{{ fullName }}</div>
					<div>{{ user.email }}</div>
					<div>Driver ID:
						{{ driver.id }}</div>
				</div>
				<div>
					<h3>Summary</h3>
					<div>Net final à payer:
						{{ data.neooNetFinalPayer|number_format(2, '.', ' ') }}
						EUR</div>
					<div>Reversement brut:
						{{ data.neooReversementBrut|number_format(2, '.', ' ') }}
						EUR</div>
					<div>Total commission:
						{{ data.neooTotalCommission|number_format(2, '.', ' ') }}
						EUR</div>
				</div>
			</div>
		</div>

		<div class="card">
			<h3>Activité & commission</h3>
			<table class="table">
				<tbody>
					<tr>
						<td>CA HT reversé plateformes</td>
						<td class="text-end">{{ data.neooTotalIn|number_format(2, '.', ' ') }}
							EUR</td>
					</tr>
					<tr>
						<td>Fixe NEOO mensuel</td>
						<td class="text-end">{{ data.neooFixed|number_format(2, '.', ' ') }}
							EUR</td>
					</tr>
					<tr>
						<td>Taux global charges URSSAF</td>
						<td class="text-end">{{ data.neooUrssaf|number_format(2, '.', ' ') }}
							%</td>
					</tr>
					<tr>
						<td>Commission variable</td>
						<td class="text-end">{{ data.neooCommissionVariable|number_format(2, '.', ' ') }}
							EUR</td>
					</tr>
					<tr>
						<td>Total commission NEOO</td>
						<td class="text-end">{{ data.neooTotalCommission|number_format(2, '.', ' ') }}
							EUR</td>
					</tr>
					<tr class="highlight">
						<td>Reversement chauffeur BRUT</td>
						<td class="text-end">{{ data.neooReversementBrut|number_format(2, '.', ' ') }}
							EUR</td>
					</tr>
				</tbody>
			</table>
		</div>

		<div class="card">
			<h3>Frais professionnels TTC (avancés)</h3>
			<table class="table">
				<thead>
					<tr>
						<th>Type</th>
						<th class="text-end">Total TTC</th>
					</tr>
				</thead>
				<tbody>
					{% if data.neooExpenseGroups is empty %}
						<tr>
							<td>-</td>
							<td class="text-end">0.00 EUR</td>
						</tr>
					{% else %}
						{% for t, v in data.neooExpenseGroups %}
							<tr>
								<td>{{ t }}</td>
								<td class="text-end">{{ v|number_format(2, '.', ' ') }}
									EUR</td>
							</tr>
						{% endfor %}
					{% endif %}
					<tr class="highlight">
						<td>Total frais TTC</td>
						<td class="text-end">{{ data.neooExpenseTotal|number_format(2, '.', ' ') }}
							EUR</td>
					</tr>
				</tbody>
			</table>
		</div>

		<div class="grid">
			<div class="card">
				<h3>TVA & C27</h3>
				<table class="table">
					<tbody>
						<tr>
							<td>TVA récupérable</td>
							<td class="text-end">{{ data.neooVatRecoverable|number_format(2, '.', ' ') }}
								EUR</td>
						</tr>
						<tr>
							<td>C27</td>
							<td class="text-end">{{ data.neooC27|number_format(2, '.', ' ') }}
								EUR</td>
						</tr>
					</tbody>
				</table>
			</div>
			<div class="card">
				<h3>Indemnités kilométriques</h3>
				<table class="table">
					<tbody>
						<tr>
							<td>Kilomètres professionnels</td>
							<td class="text-end">{{ data.neooKm|number_format(2, '.', ' ') }}
								km</td>
						</tr>
						<tr>
							<td>Taux IK</td>
							<td class="text-end">{{ data.neooFraisKm|number_format(2, '.', ' ') }}
								EUR/km</td>
						</tr>
						<tr>
							<td>Indemnité kilométrique</td>
							<td class="text-end">{{ data.neooIk|number_format(2, '.', ' ') }}
								EUR</td>
						</tr>
					</tbody>
				</table>
			</div>
		</div>

		<div class="card">
			<h3>Net social & PAS</h3>
			<table class="table">
				<tbody>
					<tr>
						<td>Net social</td>
						<td class="text-end">{{ data.neooNetSocial|number_format(2, '.', ' ') }}
							EUR</td>
					</tr>
					<tr>
						<td>Salaire brut cotisations</td>
						<td class="text-end">{{ data.neooSalaireBrutCotisations|number_format(2, '.', ' ') }}
							EUR</td>
					</tr>
					<tr>
						<td>Taux PAS</td>
						<td class="text-end">{{ data.neooTauxPas|number_format(2, '.', ' ') }}
							%</td>
					</tr>
					<tr>
						<td>Montant PAS</td>
						<td class="text-end">{{ data.neooMontantPas|number_format(2, '.', ' ') }}
							EUR</td>
					</tr>
					<tr>
						<td>Acompte</td>
						<td class="text-end">{{ data.neooAcompte|number_format(2, '.', ' ') }}
							EUR</td>
					</tr>
					<tr class="highlight">
						<td>Net social après PAS et acompte</td>
						<td class="text-end">{{ data.neooNetSocialAfter|number_format(2, '.', ' ') }}
							EUR</td>
					</tr>
				</tbody>
			</table>
		</div>

		<div class="card">
			<h3>Congés payés & net à payer</h3>
			<table class="table">
				<tbody>
					<tr>
						<td>Taux congés payés</td>
						<td class="text-end">{{ data.neooCpTaux|number_format(2, '.', ' ') }}</td>
					</tr>
					<tr>
						<td>Indemnité congés payés</td>
						<td class="text-end">{{ (data.neooCpIndemnite ?? 0)|number_format(2, '.', ' ') }}
							EUR</td>
					</tr>
					<tr>
						<td>Remboursements non imposables</td>
						<td class="text-end">{{ data.neooRemboursementsNonImposables|number_format(2, '.', ' ') }}
							EUR</td>
					</tr>
					<tr class="highlight">
						<td>NET FINAL À PAYER</td>
						<td class="text-end">{{ data.neooNetFinalPayer|number_format(2, '.', ' ') }}
							EUR</td>
					</tr>
				</tbody>
			</table>
		</div>
	</body>
</html>
