{% extends 'backoffice/layout.html.twig' %}

{% block content_title %}Neoo Fees{% endblock %}

{% block content %}
	<div class="d-flex justify-content-between align-items-center mb-3">
		<div class="text-muted small">Manage Neoo fee brackets.</div>
		<a class="btn btn-primary btn-sm" href="{{ path('backoffice_neoo_fees_new') }}">New Fee</a>
	</div>
	<div class="card shadow-sm">
		<div class="table-responsive">
			<table class="table align-middle mb-0">
				<thead class="table-light">
					<tr>
						<th>Taux</th>
						<th>Start</th>
						<th>End</th>
						<th>Updated</th>
						<th class="text-end">Actions</th>
					</tr>
				</thead>
				<tbody>
					{% if fees is empty %}
						<tr>
							<td colspan="5" class="text-center text-muted py-4">No fees found</td>
						</tr>
					{% else %}
						{% for fee in fees %}
							<tr>
								<td>{{ fee.taux|number_format(2, '.', ' ') }}</td>
								<td>{{ fee.start|number_format(2, '.', ' ') }}</td>
								<td>{{ fee.end|number_format(2, '.', ' ') }}</td>
								<td>{{ fee.updatedAt|date('Y-m-d H:i') }}</td>
								<td class="text-end">
									<a class="btn btn-sm btn-outline-primary" href="{{ path('backoffice_neoo_fees_edit', { id: fee.id }) }}">Edit</a>
									<form method="post" action="{{ path('backoffice_neoo_fees_delete', { id: fee.id }) }}" class="d-inline">
										<input type="hidden" name="_token" value="{{ csrf_token('delete_neoo_fee_' ~ fee.id) }}">
										<button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this fee?')">Delete</button>
									</form>
								</td>
							</tr>
						{% endfor %}
					{% endif %}
				</tbody>
			</table>
		</div>
	</div>
{% endblock %}
