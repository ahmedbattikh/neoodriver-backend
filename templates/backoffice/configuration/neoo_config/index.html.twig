{% extends 'backoffice/layout.html.twig' %}

{% block content_title %}Neoo Config{% endblock %}

{% block content %}
	<div class="d-flex justify-content-between align-items-center mb-3">
		<div class="text-muted small">Manage Neoo payroll configuration values.</div>
		<a class="btn btn-primary btn-sm" href="{{ path('backoffice_neoo_config_new') }}">New Config</a>
	</div>
	<div class="card shadow-sm">
		<div class="table-responsive">
			<table class="table align-middle mb-0">
				<thead class="table-light">
					<tr>
						<th>Fix Monthly</th>
						<th>Taux Congé</th>
						<th>Frais Km</th>
						<th>Taux PAS</th>
						<th>Taux URSSAF</th>
						<th>Updated</th>
						<th class="text-end">Actions</th>
					</tr>
				</thead>
				<tbody>
					{% if configs is empty %}
						<tr>
							<td colspan="7" class="text-center text-muted py-4">No configurations found</td>
						</tr>
					{% else %}
						{% for config in configs %}
							<tr>
								<td>{{ config.fixNeooMonthly|number_format(2, '.', ' ') }}</td>
								<td>{{ config.tauxConge|number_format(2, '.', ' ') }}</td>
								<td>{{ config.fraisKm|number_format(2, '.', ' ') }}</td>
								<td>{{ config.tauxPas|number_format(2, '.', ' ') }}</td>
								<td>{{ config.tauxUrssaf|number_format(2, '.', ' ') }}</td>
								<td>{{ config.updatedAt|date('Y-m-d H:i') }}</td>
								<td class="text-end">
									<a class="btn btn-sm btn-outline-primary" href="{{ path('backoffice_neoo_config_edit', { id: config.id }) }}">Edit</a>
									<form method="post" action="{{ path('backoffice_neoo_config_delete', { id: config.id }) }}" class="d-inline">
										<input type="hidden" name="_token" value="{{ csrf_token('delete_neoo_config_' ~ config.id) }}">
										<button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this config?')">Delete</button>
									</form>
								</td>
							</tr>
						{% endfor %}
					{% endif %}
				</tbody>
			</table>
		</div>
	</div>
{% endblock %}
